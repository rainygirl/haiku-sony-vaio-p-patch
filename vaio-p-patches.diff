+status_t
+WorkerThread::_MarkPartitionActive(partition_id partitionID)
+{
+	BDiskDevice device;
+	BPartition* partition;
+	if (fDDRoster.GetPartitionWithID(partitionID, &device, &partition)
+			!= B_OK) {
+		return B_ERROR;
+	}
+
+	// The disk device manager won't commit a partition-table change --
+	// including the active flag -- against a live, mounted partition. By
+	// this point in the install (called after _LaunchFinishScript(), the
+	// last thing that still needs the target mounted and writable) there's
+	// nothing left needing the mount, so drop it to actually allow this to
+	// succeed instead of silently failing every time.
+	if (partition->IsMounted()) {
+		status_t unmountStatus = partition->Unmount();
+		if (unmountStatus != B_OK) {
+			fprintf(stderr, "WorkerThread::_MarkPartitionActive(): failed "
+				"to unmount target partition: %s\n",
+				strerror(unmountStatus));
+			return unmountStatus;
+		}
+	}
+
+	if (!partition->CanEditParameters())
+		return B_NOT_SUPPORTED;
+
+	if (device.PrepareModifications() != B_OK)
+		return B_ERROR;
+
+	status_t status = partition->SetParameters("active true");
+	if (status == B_OK)
+		status = device.CommitModifications();
+	else
+		device.CancelModifications();
+
+	if (status != B_OK) {
+		fprintf(stderr, "WorkerThread::_MarkPartitionActive(): failed to "
+			"mark partition active: %s\n", strerror(status));
+	}
+	return status;
+}
+
+
+void
+WorkerThread::_WriteMBRBootCode(partition_id partitionID)
+{
+	BDiskDevice device;
+	BPartition* partition;
+	if (fDDRoster.GetPartitionWithID(partitionID, &device, &partition)
+			!= B_OK) {
+		return;
+	}
+
+	if (!partition->CanEditParameters())
+		return;
+
+	BPath devicePath;
+	if (device.GetPath(&devicePath) != B_OK)
+		return;
+
+	BString command;
+	command.SetToFormat("echo yes | writembr \"%s\"", devicePath.Path());
+	_SetStatusMessage(B_TRANSLATE("Writing master boot record."));
+	status_t status = system(command.String());
+	if (status != B_OK) {
+		fprintf(stderr, "WorkerThread::_WriteMBRBootCode(): failed to write "
+			"MBR boot code on %s\n", devicePath.Path());
+	}
+}

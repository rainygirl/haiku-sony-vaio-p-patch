+void
+UVCCamDevice::_DecodeYUY2(unsigned char* dst, unsigned char* src,
+	int32 width, int32 height, size_t dstLen, size_t srcLen)
+{
+	// YUY2/YUYV packs 2 pixels into 4 bytes: Y0 U Y1 V (4:2:2 subsampling,
+	// chroma shared between the pixel pair). B_RGB32 stores each pixel as
+	// B, G, R, - in memory (little endian).
+	int32 pixelPairs = (width * height) / 2;
+
+	// Clamp to whatever both buffers actually have room for (4 src bytes
+	// and 8 dst bytes per pixel pair). The caller's w*h-based size check
+	// has been seen to pass while the real captured (srcLen) or
+	// destination (dstLen) buffer was smaller than w*h implies -- reading
+	// or writing past that crashed the kernel (VMCache::InsertPage: an
+	// out-of-bounds access here, confirmed via a real panic during
+	// sustained capture) rather than just corrupting this one frame's
+	// pixels. Decoding fewer pixel pairs leaves the rest of dst at
+	// whatever FillFrameBuffer's memset(0) put there -- a partially
+	// black frame, not a crash.
+	int32 maxPairsBySrc = (int32)(srcLen / 4);
+	int32 maxPairsByDst = (int32)(dstLen / 8);
+	if (pixelPairs > maxPairsBySrc)
+		pixelPairs = maxPairsBySrc;
+	if (pixelPairs > maxPairsByDst)
+		pixelPairs = maxPairsByDst;
+
+	for (int32 i = 0; i < pixelPairs; i++) {
+		int y0 = src[0];
+		int u = src[1] - 128;
+		int y1 = src[2];
+		int v = src[3] - 128;
+		src += 4;
+
+		int r = (359 * v) >> 8;
+		int g = (88 * u + 183 * v) >> 8;
+		int b = (454 * u) >> 8;
+
+		dst[0] = clamp_byte(y0 + b);
+		dst[1] = clamp_byte(y0 - g);
+		dst[2] = clamp_byte(y0 + r);
+		dst[3] = 0xff;
+		dst[4] = clamp_byte(y1 + b);
+		dst[5] = clamp_byte(y1 - g);
+		dst[6] = clamp_byte(y1 + r);
+		dst[7] = 0xff;
+		dst += 8;
+	}
+}

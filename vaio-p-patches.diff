diff --git a/src/add-ons/kernel/power/cpufreq/intel_est/intel_est.cpp b/src/add-ons/kernel/power/cpufreq/intel_est/intel_est.cpp
new file mode 100644
index 0000000000..442fd236a9
--- /dev/null
+++ b/src/add-ons/kernel/power/cpufreq/intel_est/intel_est.cpp
@@ -0,0 +1,596 @@
+/*
+ * Copyright 2026, Haiku, Inc. All Rights Reserved.
+ * Distributed under the terms of the MIT License.
+ *
+ * Legacy Intel Enhanced SpeedStep (EST) cpufreq driver.
+ *
+ * The in-tree intel_pstates driver only handles HWP (hardware-managed
+ * P-states), which arrived with Skylake. Older EST-capable CPUs -- e.g.
+ * the first-generation Atom (Bonnell) in the Sony VAIO P -- advertise
+ * IA32_FEATURE_EST in CPUID but not HWP, so intel_pstates rejects them and
+ * the machine runs pinned at a single frequency forever ("no valid
+ * cpufreq module found").
+ *
+ * Legacy EST doesn't expose its P-state table through an MSR the way HWP
+ * does; the available (frequency, control-value) pairs come from the ACPI
+ * _PSS object under each processor, and switching is done by writing the
+ * control value to the register _PCT describes. On most EST-era chips
+ * that's IA32_PERF_CTL (MSR 0x199), the same MSR HWP-era chips use, just
+ * fed ACPI-supplied values instead of platform-info-derived ratios. Some
+ * platforms (e.g. the Poulsbo-based Sony VAIO P) instead describe a
+ * SystemMemory-space register in _PCT -- P-state switching there is a
+ * chipset MMIO write, not an MSR write at all. This driver reads _PSS/_PCT
+ * via ACPI and supports both control methods; anything else (e.g.
+ * SystemIO) is left alone.
+ */
+
+
+#include <cpufreq.h>
+#include <KernelExport.h>
+#include <new>
+#include <stdlib.h>
+
+#include <ACPI.h>
+#include <arch_cpu.h>
+#include <arch_system_info.h>
+#include <cpu.h>
+#include <smp.h>
+#include <util/AutoLock.h>
+
+#include <device_manager.h>
+
+
+#define INTEL_EST_MODULE_NAME	CPUFREQ_MODULES_PREFIX "/intel_est/v1"
+
+
+// _OSC/_PDC capability bits (mirrors x86_acpi_cstates' acpi_cpuidle.cpp).
+#define ACPI_PDC_REVID			0x1
+#define ACPI_PDC_P_FFH			(1 << 0)
+#define ACPI_PDC_C_C1_HALT		(1 << 1)
+#define ACPI_PDC_T_FFH			(1 << 2)
+#define ACPI_PDC_SMP_C1PT		(1 << 3)
+#define ACPI_PDC_SMP_C2C3		(1 << 4)
+#define ACPI_PDC_SMP_P_SW		(1 << 5)
+#define ACPI_PDC_SMP_C_SW		(1 << 6)
+#define ACPI_PDC_SMP_T_SW		(1 << 7)
+#define ACPI_PDC_C_C1_FFH		(1 << 8)
+#define ACPI_PDC_C_C2C3_FFH		(1 << 9)
+#define ACPI_PDC_P_HWCOORD		(1 << 11)
+
+// Not in arch_cpu.h: the architectural MISC_ENABLE MSR. Bit 16 gates EST
+// -- while it's clear, writes to IA32_PERF_CTL are silently ignored, so
+// having the CPUID feature and a valid _PSS isn't enough by itself.
+// Firmware usually sets it, but not dependably on every machine/boot
+// path.
+#define IA32_MSR_MISC_ENABLE		0x1a0
+#define IA32_MISC_ENABLE_EST		(1ULL << 16)
+
+
+const int kMinimalInterval = 50000;
+#define MAX_PSTATES 16
+
+
+// Layout of a "Register()" ASL resource descriptor, i.e. a Generic Address
+// Structure wrapped in a small-resource header -- matches what _PCT's
+// package elements decode to (mirrors x86_acpi_cstates' acpicpu_reg).
+struct acpi_gas_reg {
+	uint8	reg_desc;
+	uint16	reg_reslen;
+	uint8	reg_spaceid;
+	uint8	reg_bitwidth;
+	uint8	reg_bitoffset;
+	uint8	reg_accesssize;
+	uint64	reg_addr;
+} __attribute__((packed));
+
+
+struct pstate {
+	uint32	frequencyMHz;
+	uint32	control;	// value to write to the _PCT control register
+};
+
+
+// The control register _PCT describes, resolved once at init and reused
+// for every P-state transition.
+enum control_method {
+	CONTROL_METHOD_NONE = 0,
+	CONTROL_METHOD_FIXED_HW,	// IA32_PERF_CTL (MSR 0x199)
+	CONTROL_METHOD_SYSTEM_MEMORY	// chipset MMIO register
+};
+
+static control_method sControlMethod = CONTROL_METHOD_NONE;
+static area_id sControlArea = -1;
+static vuint8* sControlBase;	// exact register address within the mapping
+static uint8 sControlBitWidth;
+
+
+// P-states as read from _PSS, sorted highest-performance (index 0) to
+// lowest. _PSS itself lists them highest-first already, but we normalize
+// to be safe. Shared across CPUs: on every EST laptop of this era all
+// logical CPUs share one identical table.
+static pstate sPStates[MAX_PSTATES];
+static int32 sPStateCount;
+
+static bool sAvoidBoost;
+
+
+struct CPUEntry {
+				CPUEntry();
+
+	int32		fCurrentState;	// index into sPStates
+	bigtime_t	fLastUpdate;
+} CACHE_LINE_ALIGN;
+static CPUEntry* sCPUEntries;
+
+
+CPUEntry::CPUEntry()
+	:
+	fCurrentState(-1),
+	fLastUpdate(0)
+{
+}
+
+
+static acpi_module_info* sAcpi;
+static device_manager_info* sDeviceManager;
+
+
+static bool
+est_cpu_supported(cpu_ent* cpu)
+{
+	if (cpu->arch.vendor != VENDOR_INTEL)
+		return false;
+	// EST is advertised in CPUID.1:ECX[7].
+	if (!x86_check_feature(IA32_FEATURE_EXT_EST, FEATURE_EXT))
+		return false;
+	// If HWP is present, the dedicated intel_pstates driver (higher rank)
+	// handles it -- don't fight over those CPUs.
+	if (x86_check_feature(IA32_FEATURE_HWP, FEATURE_6_EAX))
+		return false;
+	return true;
+}
+
+
+static void
+set_pstate_index(int32 index)
+{
+	CPUEntry* entry = &sCPUEntries[smp_get_current_cpu()];
+	if (index < 0)
+		index = 0;
+	if (index >= sPStateCount)
+		index = sPStateCount - 1;
+
+	if (entry->fCurrentState == index)
+		return;
+
+	entry->fCurrentState = index;
+	entry->fLastUpdate = system_time();
+
+	uint32 control = sPStates[index].control;
+
+	if (sControlMethod == CONTROL_METHOD_SYSTEM_MEMORY) {
+		// Dedicated MMIO register -- write the ACPI-supplied control value
+		// through as-is, sized to the width _PCT declared. Unlike the MSR
+		// case there's nothing else sharing this register to preserve.
+		if (sControlBitWidth <= 8)
+			*sControlBase = (uint8)control;
+		else if (sControlBitWidth <= 16)
+			*(vuint16*)sControlBase = (uint16)control;
+		else
+			*(vuint32*)sControlBase = control;
+		return;
+	}
+
+	// CONTROL_METHOD_FIXED_HW: IA32_PERF_CTL, bits 15:0 carry the target
+	// performance state; the ACPI _PSS control field is already in that
+	// encoding for FixedHW EST, so it can be written through directly
+	// (preserving the upper bits, which on some parts hold the
+	// IDA/turbo-disable flag).
+	uint64 perfCtl = x86_read_msr(IA32_MSR_PERF_CTL);
+	perfCtl &= ~(uint64)0xffff;
+	perfCtl |= control & 0xffff;
+	x86_write_msr(IA32_MSR_PERF_CTL, perfCtl);
+}
+
+
+static void
+set_normal_pstate(void* /* dummy */, int cpu)
+{
+	// EST must be globally enabled before IA32_PERF_CTL writes have any
+	// effect; per-logical-CPU, since MISC_ENABLE is per-thread on some
+	// parts. Firmware usually did this already, but don't rely on it.
+	uint64 miscEnable = x86_read_msr(IA32_MSR_MISC_ENABLE);
+	if ((miscEnable & IA32_MISC_ENABLE_EST) == 0) {
+		x86_write_msr(IA32_MSR_MISC_ENABLE,
+			miscEnable | IA32_MISC_ENABLE_EST);
+	}
+
+	// Default to the highest-performance state; the scheduler drives it
+	// down from there via decrease_performance().
+	CPUEntry* entry = &sCPUEntries[cpu];
+	entry->fCurrentState = -1;
+	set_pstate_index(0);
+}
+
+
+static void
+est_set_scheduler_mode(scheduler_mode mode)
+{
+	sAvoidBoost = mode == SCHEDULER_MODE_POWER_SAVING;
+}
+
+
+static status_t
+est_increase_performance(int delta)
+{
+	CPUEntry* entry = &sCPUEntries[smp_get_current_cpu()];
+
+	if (system_time() - entry->fLastUpdate < kMinimalInterval)
+		return B_OK;
+
+	// Lower index == higher performance. Move up (toward index 0) by a
+	// fraction of the remaining headroom proportional to delta.
+	int32 current = entry->fCurrentState < 0 ? sPStateCount - 1
+		: entry->fCurrentState;
+	int32 step = current * delta / kCPUPerformanceScaleMax;
+	if (step < 1 && delta > 0)
+		step = 1;
+	int32 target = current - step;
+
+	// In power-saving mode, never jump straight to the top ("boost")
+	// state -- cap at the second-highest.
+	if (sAvoidBoost && target < 1 && sPStateCount > 1)
+		target = 1;
+
+	set_pstate_index(target);
+	return B_OK;
+}
+
+
+static status_t
+est_decrease_performance(int delta)
+{
+	CPUEntry* entry = &sCPUEntries[smp_get_current_cpu()];
+
+	if (system_time() - entry->fLastUpdate < kMinimalInterval)
+		return B_OK;
+
+	int32 current = entry->fCurrentState < 0 ? 0 : entry->fCurrentState;
+	int32 room = (sPStateCount - 1) - current;
+	int32 step = room * delta / kCPUPerformanceScaleMax;
+	if (step < 1 && delta > 0)
+		step = 1;
+
+	set_pstate_index(current + step);
+	return B_OK;
+}
+
+
+static void
+sort_pstates_by_performance()
+{
+	// _PSS is specified highest-performance-first, but sort defensively
+	// (higher frequency == higher performance == lower index).
+	for (int32 i = 0; i < sPStateCount - 1; i++) {
+		for (int32 j = i + 1; j < sPStateCount; j++) {
+			if (sPStates[j].frequencyMHz > sPStates[i].frequencyMHz) {
+				pstate tmp = sPStates[i];
+				sPStates[i] = sPStates[j];
+				sPStates[j] = tmp;
+			}
+		}
+	}
+}
+
+
+// On some platforms (e.g. the Sony VAIO P's Atom Z520) _PSS/_PCT don't
+// exist in the static DSDT at all -- the BIOS injects them via an AML
+// Load() of an OEM SSDT that's only triggered as a side effect of
+// evaluating _OSC (observed on real hardware: the dynamic table load
+// happens right after _OSC runs, and cpuidle's _CST evaluation -- which
+// also evaluates _OSC first -- succeeds right after). Do the same here
+// before ever giving up on _PSS/_PCT. Best-effort: if _OSC and the _PDC
+// fallback both fail, keep going and let prepare_control_register()/read_pss()
+// report their own failure as before.
+static void
+acpi_eval_osc_or_pdc(acpi_device_module_info* acpi, acpi_device cookie)
+{
+	uint32 pdcCap = ACPI_PDC_C_C1_HALT | ACPI_PDC_SMP_C1PT | ACPI_PDC_SMP_C2C3
+		| ACPI_PDC_SMP_P_SW | ACPI_PDC_SMP_C_SW | ACPI_PDC_SMP_T_SW
+		| ACPI_PDC_C_C1_FFH | ACPI_PDC_C_C2C3_FFH | ACPI_PDC_P_FFH
+		| ACPI_PDC_P_HWCOORD | ACPI_PDC_T_FFH;
+
+	// _OSC (guid for Intel platform)
+	static uint8 uuid[] = {
+		0x16, 0xA6, 0x77, 0x40, 0x0C, 0x29, 0xBE, 0x47,
+		0x9E, 0xBD, 0xD8, 0x70, 0x58, 0x71, 0x39, 0x53
+	};
+	uint32 oscCap[2] = { 0, pdcCap };
+
+	acpi_objects arg;
+	acpi_object_type obj[4];
+	arg.count = 4;
+	arg.pointer = obj;
+	obj[0].object_type = ACPI_TYPE_BUFFER;
+	obj[0].buffer.length = sizeof(uuid);
+	obj[0].buffer.buffer = uuid;
+	obj[1].object_type = ACPI_TYPE_INTEGER;
+	obj[1].integer.integer = ACPI_PDC_REVID;
+	obj[2].object_type = ACPI_TYPE_INTEGER;
+	obj[2].integer.integer = sizeof(oscCap) / sizeof(oscCap[0]);
+	obj[3].object_type = ACPI_TYPE_BUFFER;
+	obj[3].buffer.length = sizeof(oscCap);
+	obj[3].buffer.buffer = (void*)oscCap;
+
+	acpi_data buf;
+	buf.pointer = NULL;
+	buf.length = ACPI_ALLOCATE_LOCAL_BUFFER;
+	status_t status = acpi->evaluate_method(cookie, "_OSC", &arg, &buf);
+	if (buf.pointer != NULL)
+		free(buf.pointer);
+	if (status == B_OK)
+		return;
+
+	// _PDC fallback (deprecated pre-3.0 mechanism, same intent as _OSC).
+	acpi_objects pdcArg;
+	acpi_object_type pdcObj;
+	uint32 pdcBuf[3] = { 1, 1, pdcCap };
+	pdcArg.count = 1;
+	pdcArg.pointer = &pdcObj;
+	pdcObj.object_type = ACPI_TYPE_BUFFER;
+	pdcObj.buffer.length = sizeof(pdcBuf);
+	pdcObj.buffer.buffer = pdcBuf;
+	acpi->evaluate_method(cookie, "_PDC", &pdcArg, NULL);
+}
+
+
+// Undo whatever prepare_control_register() set up, for a candidate that
+// didn't pan out (its _PSS turned out unusable) or on module uninit.
+static void
+release_control_register()
+{
+	if (sControlArea >= 0) {
+		delete_area(sControlArea);
+		sControlArea = -1;
+	}
+	sControlBase = NULL;
+	sControlBitWidth = 0;
+	sControlMethod = CONTROL_METHOD_NONE;
+}
+
+
+// Parse _PCT's control register and prepare whatever's needed to drive it:
+// nothing for FixedHW (MSR 0x199 is always accessible), or a kernel MMIO
+// mapping for SystemMemory. Rejects anything else (e.g. SystemIO).
+static status_t
+prepare_control_register(acpi_device_module_info* acpi, acpi_device cookie)
+{
+	acpi_data buffer;
+	buffer.pointer = NULL;
+	buffer.length = ACPI_ALLOCATE_BUFFER;
+
+	status_t status = acpi->evaluate_method(cookie, "_PCT", NULL, &buffer);
+	if (status != B_OK)
+		return status;
+
+	acpi_object_type* pct = (acpi_object_type*)buffer.pointer;
+	status = B_NOT_SUPPORTED;
+	if (pct->object_type == ACPI_TYPE_PACKAGE && pct->package.count >= 2) {
+		// Both elements are Register() resource descriptors; element 0 is
+		// the control register.
+		acpi_object_type* control = &pct->package.objects[0];
+		if (control->object_type == ACPI_TYPE_BUFFER
+			&& control->buffer.length >= sizeof(acpi_gas_reg)) {
+			acpi_gas_reg* reg = (acpi_gas_reg*)control->buffer.buffer;
+
+			if (reg->reg_spaceid == ACPI_ADR_SPACE_FIXED_HARDWARE) {
+				sControlMethod = CONTROL_METHOD_FIXED_HW;
+				status = B_OK;
+			} else if (reg->reg_spaceid == ACPI_ADR_SPACE_SYSTEM_MEMORY
+					&& reg->reg_addr != 0
+					&& reg->reg_bitwidth > 0 && reg->reg_bitwidth <= 32) {
+				phys_addr_t physPage = reg->reg_addr & ~(phys_addr_t)(B_PAGE_SIZE - 1);
+				uint32 pageOffset = reg->reg_addr & (B_PAGE_SIZE - 1);
+				size_t regBytes = (reg->reg_bitwidth + 7) / 8;
+				size_t mapSize = ((pageOffset + regBytes + B_PAGE_SIZE - 1)
+					/ B_PAGE_SIZE) * B_PAGE_SIZE;
+
+				void* mappedBase;
+				area_id area = map_physical_memory("intel_est _PCT control",
+					physPage, mapSize, B_ANY_KERNEL_ADDRESS,
+					B_KERNEL_READ_AREA | B_KERNEL_WRITE_AREA, &mappedBase);
+				if (area >= 0) {
+					sControlArea = area;
+					sControlBase = (vuint8*)mappedBase + pageOffset;
+					sControlBitWidth = reg->reg_bitwidth;
+					sControlMethod = CONTROL_METHOD_SYSTEM_MEMORY;
+					status = B_OK;
+				} else {
+					dprintf("intel_est: failed to map _PCT MMIO control "
+						"register: 0x%" B_PRIx32 "\n", (uint32)area);
+					status = area;
+				}
+			}
+		}
+	}
+
+	free(buffer.pointer);
+	return status;
+}
+
+
+static status_t
+read_pss(acpi_device_module_info* acpi, acpi_device cookie)
+{
+	acpi_data buffer;
+	buffer.pointer = NULL;
+	buffer.length = ACPI_ALLOCATE_BUFFER;
+
+	status_t status = acpi->evaluate_method(cookie, "_PSS", NULL, &buffer);
+	if (status != B_OK) {
+		dprintf("intel_est: _PSS evaluate_method failed: 0x%" B_PRIx32 "\n",
+			(uint32)status);
+		return status;
+	}
+
+	acpi_object_type* pss = (acpi_object_type*)buffer.pointer;
+	if (pss->object_type != ACPI_TYPE_PACKAGE || pss->package.count == 0) {
+		free(buffer.pointer);
+		return B_BAD_DATA;
+	}
+
+	int32 count = 0;
+	for (uint32 i = 0; i < pss->package.count && count < MAX_PSTATES; i++) {
+		acpi_object_type* state = &pss->package.objects[i];
+		// Each _PSS entry is a package of 6 integers:
+		// CoreFrequency(MHz), Power(mW), Latency, BusMasterLatency,
+		// Control, Status.
+		if (state->object_type != ACPI_TYPE_PACKAGE
+			|| state->package.count < 6)
+			continue;
+		if (state->package.objects[0].object_type != ACPI_TYPE_INTEGER
+			|| state->package.objects[4].object_type != ACPI_TYPE_INTEGER)
+			continue;
+
+		sPStates[count].frequencyMHz
+			= (uint32)state->package.objects[0].integer.integer;
+		sPStates[count].control
+			= (uint32)state->package.objects[4].integer.integer;
+		count++;
+	}
+
+	free(buffer.pointer);
+
+	if (count == 0)
+		return B_BAD_DATA;
+
+	sPStateCount = count;
+	sort_pstates_by_performance();
+	return B_OK;
+}
+
+
+static status_t
+init_est()
+{
+	if (!x86_check_feature(IA32_FEATURE_MSR, FEATURE_COMMON))
+		return B_ERROR;
+
+	int32 cpuCount = smp_get_num_cpus();
+	for (int32 i = 0; i < cpuCount; i++) {
+		if (!est_cpu_supported(&gCPU[i]))
+			return B_ERROR;
+	}
+
+	// Find any ACPI processor node and read its _PCT/_PSS. The table is
+	// identical across all logical CPUs on these platforms.
+	device_node* root = sDeviceManager->get_root_node();
+	device_attr acpiAttrs[] = {
+		{ B_DEVICE_BUS, B_STRING_TYPE, { .string = "acpi" }},
+		{ ACPI_DEVICE_TYPE_ITEM, B_UINT32_TYPE,
+			{ .ui32 = ACPI_TYPE_PROCESSOR }},
+		{ NULL }
+	};
+
+	status_t status = B_ERROR;
+	device_node* processor = NULL;
+	while (sDeviceManager->find_child_node(root, acpiAttrs, &processor)
+			== B_OK) {
+		acpi_device_module_info* acpi;
+		acpi_device cookie;

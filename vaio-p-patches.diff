@@ -477,6 +477,17 @@ vfs_mount_boot_file_system(kernel_args* args)
 	if (status < B_OK) {
 		panic("get_boot_partitions failed!");
 	}
+
+	const int32 kBootPartitionRetries = 40;
+	const bigtime_t kBootPartitionRetryInterval = 250000;
+	for (int32 i = 0; partitions.IsEmpty() && i < kBootPartitionRetries; i++) {
+		snooze(kBootPartitionRetryInterval);
+		status = get_boot_partitions(bootVolume, partitions);
+		if (status < B_OK) {
+			panic("get_boot_partitions failed!");
+		}
+	}
+
 	if (partitions.IsEmpty()) {
 		panic("did not find any boot partitions! @! syslog | tail 15");
 	}

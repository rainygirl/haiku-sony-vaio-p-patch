+static void
+dump_redirection_entry(struct ioapic& ioapic, uint8 pin)
+{
+	uint64 entry = ioapic_read_64(ioapic, IO_APIC_REDIRECTION_TABLE + pin * 2);
+	int32 gsi = ioapic.global_interrupt_base + pin;
+	uint8 vector = entry & IO_APIC_INTERRUPT_VECTOR_MASK;
+
+	kprintf("io-apic %u pin %2u (gsi %3" B_PRId32 "): raw 0x%016" B_PRIx64
+		" vector %3u (irq %3d) %s %s %s %s dest %u\n",
+		ioapic.number, pin, gsi, entry, vector,
+		vector - ARCH_INTERRUPT_BASE,
+		(entry & IO_APIC_INTERRUPT_MASKED) != 0 ? "masked  " : "unmasked",
+		(entry & IO_APIC_TRIGGER_MODE_MASK) != 0 ? "level" : "edge ",
+		(entry & IO_APIC_PIN_POLARITY_MASK) != 0 ? "low activ " : "high active",
+		(entry & IO_APIC_REMOTE_IRR) != 0 ? "IRR-pending" : "           ",
+		(uint8)((entry >> IO_APIC_DESTINATION_FIELD_SHIFT)
+			& IO_APIC_DESTINATION_FIELD_MASK));
+}
+
+
+static int
+dump_ioapics(int argc, char** argv)
+{
+	if (sIOAPICs == NULL) {
+		kprintf("no io-apics in use (legacy PIC or safemode disabled)\n");
+		return 0;
+	}
+
+	if (argc > 1) {
+		int32 gsi = atoi(argv[1]);
+		struct ioapic* ioapic = find_ioapic(gsi);
+		if (ioapic == NULL) {
+			kprintf("gsi %" B_PRId32 " is not handled by any io-apic\n", gsi);
+			return 0;
+		}
+
+		print_ioapic(*ioapic);
+		dump_redirection_entry(*ioapic, gsi - ioapic->global_interrupt_base);
+		return 0;
+	}
+
+	for (struct ioapic* ioapic = sIOAPICs; ioapic != NULL;
+			ioapic = ioapic->next) {
+		print_ioapic(*ioapic);
+		for (int32 pin = 0; pin <= ioapic->max_redirection_entry; pin++)
+			dump_redirection_entry(*ioapic, pin);
+	}
+
+	return 0;
+}

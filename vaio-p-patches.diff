+int32
+BUSBEndpoint::QueueIsochronous(void *data, size_t length,
+	usb_iso_packet_descriptor *packetDescriptors, uint32 packetCount) const
+{
+	// Submits like IsochronousTransfer(), but returns immediately with a
+	// request ID instead of blocking for completion -- pair with
+	// WaitIsochronous() to actually retrieve the result later. Doing this
+	// lets a caller have two isochronous transfers genuinely outstanding
+	// with the host controller at once (queue both, then wait on each),
+	// which matters specifically for isochronous IN: the schedule gap
+	// between one blocking IsochronousTransfer() call and the next costs
+	// real captured data on every single call (see
+	// EHCI::SubmitIsochronous()'s fNextStartingFrame chaining, which only
+	// kicks in when the next request is queued before the previous one
+	// completes).
+	if (length > 0 && data == NULL)
+		return B_BAD_VALUE;
+
+	usb_raw_command command;
+	command.isochronous.interface = fInterface->Index();
+	command.isochronous.endpoint = fIndex;
+	command.isochronous.data = data;
+	command.isochronous.length = length;
+	command.isochronous.packet_descriptors = packetDescriptors;
+	command.isochronous.packet_count = packetCount;
+	command.isochronous.request_id = -1;
+
+	if (ioctl(fRawFD, B_USB_RAW_COMMAND_QUEUE_ISOCHRONOUS, &command,
+		sizeof(command)) || command.isochronous.status != B_USB_RAW_STATUS_SUCCESS)
+		return B_ERROR;
+
+	return command.isochronous.request_id;
+}
+
+
+ssize_t
+BUSBEndpoint::WaitIsochronous(int32 requestID) const
+{
+	// Blocks for the completion of a transfer previously started with
+	// QueueIsochronous(), identified by the request ID it returned. The
+	// packet descriptors passed to that QueueIsochronous() call are
+	// updated in place with the results, exactly as IsochronousTransfer()
+	// would have updated them.
+	usb_raw_command command;
+	memset(&command, 0, sizeof(command));
+	command.isochronous.request_id = requestID;
+
+	if (ioctl(fRawFD, B_USB_RAW_COMMAND_WAIT_ISOCHRONOUS, &command,
+		sizeof(command)) || command.isochronous.status != B_USB_RAW_STATUS_SUCCESS)
+		return B_ERROR;
+
+	return command.isochronous.length;
+}

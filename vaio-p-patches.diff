+int32
+CamDevice::IsoConsumerThread()
+{
+	int cur = 0;
+	while (true) {
+		// Told to exit by CamDevice::StopTransfer() deleting the
+		// semaphores out from under us once the producer/DataPumpThread
+		// has stopped issuing new requests -- acquire_sem() on a deleted
+		// semaphore returns an error instead of blocking forever.
+		if (acquire_sem(fIsoBufferReady[cur]) != B_OK)
+			break;
+		if (!fTransferEnabled)
+			break;
+
+		// Deliberately not taking fLocker here: fDataInput is set once,
+		// before StartTransfer() is ever called (see UVCCamDevice's
+		// constructor), and never reassigned while streaming, so it
+		// needs no protection -- and the producer thread (DataPumpThread)
+		// holds fLocker for the full duration of its blocking
+		// IsochronousTransfer() call, so contending on the same lock here
+		// would serialize this thread behind that call and defeat the
+		// entire point of pipelining the two.
+		ssize_t len = fIsoTransferLen[cur];
+		if (len > 0 && fDataInput) {
+			int bufferIndex = 0;
+			for (int i = 0; i < fIsoNumPacketDescriptors; i++) {
+				int actualLength
+					= fIsoPacketDescriptors[cur][i].actual_length;
+				if (actualLength > 0) {
+					fDataInput->Write(&fIsoBuffer[cur][bufferIndex],
+						actualLength);
+				}
+				// Each packet occupies a fixed fIsoMaxPacketSize-sized
+				// slot in fIsoBuffer[cur] -- that's the stride the host
+				// controller used when writing the DMA buffer (laid out
+				// before actual per-packet lengths are known), not the
+				// variable actualLength. Advancing by actualLength
+				// instead drifts the read offset out of sync with the
+				// real data as soon as any packet returns less than
+				// requested (routine for isochronous transfers),
+				// scrambling every packet after it.
+				bufferIndex += fIsoMaxPacketSize;
+			}
+		}
+
+		release_sem(fIsoBufferFree[cur]);
+		cur = 1 - cur;
+	}
+	return 0;
+}

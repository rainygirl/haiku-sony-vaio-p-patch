diff --git a/src/add-ons/kernel/drivers/power/sony_ec/sony_ec.cpp b/src/add-ons/kernel/drivers/power/sony_ec/sony_ec.cpp
new file mode 100644
index 0000000000..880a2d8719
--- /dev/null
+++ b/src/add-ons/kernel/drivers/power/sony_ec/sony_ec.cpp
@@ -0,0 +1,516 @@
+/*
+ * Copyright 2026, Haiku, Inc. All rights reserved.
+ * Distributed under the terms of the MIT License.
+ *
+ * Diagnostic/bring-up driver for the Sony "SNC" notebook control ACPI
+ * device (HID "SNY5001"), found on Sony VAIO laptops of this era.
+ *
+ * This does NOT reimplement Linux's sony-laptop.c (which is GPL licensed
+ * and can't be copied into this MIT-licensed tree); it's an independent
+ * implementation written from an understanding of the SNC calling
+ * convention gathered by reading that driver and Sony's own published
+ * ACPI SNC readme. The convention, in short:
+ *
+ *   - The SNC device exposes up to 16 "capability" slots. Calling SN00
+ *     with an argument of (slot + 0x20) returns the vendor-defined
+ *     "handle" value assigned to that slot on this particular model (0
+ *     if unused). Which handle ends up in which slot is BIOS/model
+ *     specific and has to be discovered at runtime -- there is no fixed
+ *     mapping.
+ *   - SN02 takes a bitmask (obtained via SN00 with argument 0x10) and
+ *     enables ACPI Notify events for the capabilities present.
+ *   - Runtime ACPI Notify events on the SNC device use codes of
+ *     (0x90 + slot), i.e. they identify a slot, not a handle directly;
+ *     the handle has to be looked back up from the table above.
+ *   - SN05 acknowledges/clears an event for a given slot.
+ *   - Screen brightness is a separate, simpler pair of methods: GBRT
+ *     (get, no argument) and SBRT (set, one integer argument), which
+ *     don't go through the capability table at all.
+ *
+ * This driver only logs what it finds (capability table contents,
+ * brightness, and raw Notify event/slot/handle numbers) via dprintf, so
+ * the real per-model handle assignments (which slot is the wireless
+ * kill switch, which is the keyboard backlight, etc.) can be read out of
+ * the syslog on real hardware instead of guessed at. Once that's known,
+ * the interesting handles can be given real meaning (rfkill state,
+ * hotkey delivery, ...) as a follow-up.
+ */
+
+
+#include <ACPI.h>
+
+#include <stdlib.h>
+#include <string.h>
+
+
+#define SONY_EC_MODULE_NAME "drivers/power/sony_ec/driver_v1"
+#define SONY_EC_DEVICE_MODULE_NAME "drivers/power/sony_ec/device_v1"
+
+#define SONY_EC_HID "SNY5001"
+
+#define SONY_EC_CAP_SLOT_COUNT 16
+#define SONY_EC_CAP_SLOT_BASE 0x20
+#define SONY_EC_EVENT_BASE 0x90
+
+#define ERROR(x...)	dprintf("sony_ec: " x)
+#define TRACE(x...)	dprintf("sony_ec: " x)
+
+
+static device_manager_info *sDeviceManager;
+static struct acpi_module_info *sAcpi;
+
+
+typedef struct {
+	device_node *node;
+	acpi_device_module_info *acpi;
+	acpi_device acpi_cookie;
+
+	uint16 capabilities[SONY_EC_CAP_SLOT_COUNT];
+	uint32 statusValue[SONY_EC_CAP_SLOT_COUNT];
+	uint32 brightness;
+} sony_ec_device_info;
+
+static sony_ec_device_info *sSonyEcDevice;
+
+
+static status_t
+sony_ec_call_int(sony_ec_device_info *device, const char *method,
+	bool hasArgument, uint32 argument, uint32 *_result)
+{
+	acpi_object_type argumentObject;
+	acpi_objects arguments;
+	acpi_objects *argumentsPointer = NULL;
+
+	if (hasArgument) {
+		argumentObject.object_type = ACPI_TYPE_INTEGER;
+		argumentObject.integer.integer = argument;
+		arguments.count = 1;
+		arguments.pointer = &argumentObject;
+		argumentsPointer = &arguments;
+	}
+
+	uint8 resultBuffer[64];
+	memset(resultBuffer, 0, sizeof(resultBuffer));
+	acpi_data buffer;
+	buffer.pointer = resultBuffer;
+	buffer.length = sizeof(resultBuffer);
+
+	status_t status = device->acpi->evaluate_method(device->acpi_cookie,
+		method, argumentsPointer, &buffer);
+	if (status != B_OK)
+		return status;
+
+	// Some SNC methods (SBRT in particular) are setters with no meaningful
+	// return value -- the AML has no Return statement, so the buffer stays
+	// empty. That's not a failure: the method call itself already
+	// succeeded above. Only decode a result if the callee actually wants
+	// one and something recognizable came back; otherwise just report
+	// success with *_result left untouched.
+	if (buffer.length == 0)
+		return B_OK;
+
+	acpi_object_type *object = (acpi_object_type *)buffer.pointer;
+	if (object->object_type == ACPI_TYPE_INTEGER) {
+		*_result = (uint32)object->integer.integer;
+		return B_OK;
+	}
+
+	if (object->object_type == ACPI_TYPE_BUFFER && object->buffer.length >= 1) {
+		uint32 value = 0;
+		size_t count = min_c(object->buffer.length, sizeof(value));
+		memcpy(&value, object->buffer.buffer, count);
+		*_result = value;
+		return B_OK;
+	}
+
+	return B_OK;
+}
+
+
+static status_t
+sony_ec_call_handle(sony_ec_device_info *device, uint16 handle,
+	uint32 argument, uint32 *_result)
+{
+	for (int32 i = 0; i < SONY_EC_CAP_SLOT_COUNT; i++) {
+		if (device->capabilities[i] != handle)
+			continue;
+
+		return sony_ec_call_int(device, "SN07", true, i | argument, _result);
+	}
+
+	return B_ENTRY_NOT_FOUND;
+}
+
+
+static void
+sony_ec_probe_capabilities(sony_ec_device_info *device)
+{
+	for (int32 i = 0; i < SONY_EC_CAP_SLOT_COUNT; i++) {
+		uint32 result = 0;
+		status_t status = sony_ec_call_int(device, "SN00", true,
+			SONY_EC_CAP_SLOT_BASE + i, &result);
+		device->capabilities[i] = (status == B_OK) ? (uint16)result : 0;
+		if (status == B_OK && result != 0) {
+			TRACE("capability slot %" B_PRId32 ": handle 0x%04" B_PRIx32
+				"\n", i, result);
+		}
+	}
+
+	// Diagnostic only: read back a "status" value (argument 0x0100, the
+	// same convention used to read the wireless kill switch's state) for
+	// every discovered handle. This doesn't control anything by itself,
+	// but gives real per-handle data to work from -- e.g. a handle whose
+	// value visibly tracks something we can toggle (like an indicator
+	// LED) instead of guessing blind.
+	for (int32 i = 0; i < SONY_EC_CAP_SLOT_COUNT; i++) {
+		if (device->capabilities[i] == 0)
+			continue;
+
+		uint32 result = 0;
+		status_t status = sony_ec_call_int(device, "SN07", true,
+			i | 0x0100, &result);
+		device->statusValue[i] = result;
+		TRACE("capability slot %" B_PRId32 " (handle 0x%04x) status: %s, "
+			"value 0x%04" B_PRIx32 "\n", i, device->capabilities[i],
+			strerror(status), result);
+	}
+
+	// The hotkey handles need to be "armed" once with a 0 argument before
+	// they start generating Notify events for Fn key presses -- unlike
+	// e.g. the wireless kill switch handle, which reports events out of
+	// the box.
+	static const uint16 kHotkeyHandles[] = { 0x0100, 0x0101, 0x0102, 0x0127 };
+	for (size_t i = 0; i < B_COUNT_OF(kHotkeyHandles); i++) {
+		uint32 result = 0;
+		status_t status = sony_ec_call_handle(device, kHotkeyHandles[i], 0,
+			&result);
+		if (status == B_OK) {
+			TRACE("armed hotkey handle 0x%04x\n", kHotkeyHandles[i]);
+		}
+	}
+
+	uint32 brightness = 0;
+	if (sony_ec_call_int(device, "GBRT", false, 0, &brightness) == B_OK) {
+		device->brightness = brightness;
+		TRACE("current brightness (GBRT): %" B_PRIu32 "\n", brightness);
+	} else {
+		TRACE("GBRT not available on this model\n");
+	}
+
+	uint32 eventMask = 0;
+	if (sony_ec_call_int(device, "SN00", true, 0x10, &eventMask) == B_OK) {
+		uint32 enableResult = 0;
+		status_t status = sony_ec_call_int(device, "SN02", true, eventMask,
+			&enableResult);
+		TRACE("enabling events (mask 0x%04" B_PRIx32 "): %s\n", eventMask,
+			strerror(status));
+	}
+}
+
+
+static void
+sony_ec_notify_handler(acpi_handle _device, uint32 value, void *context)
+{
+	sony_ec_device_info *device = (sony_ec_device_info *)context;
+
+	TRACE("notify event 0x%04" B_PRIx32 "\n", value);
+
+	if (value < SONY_EC_EVENT_BASE)
+		return;
+
+	uint32 offset = value - SONY_EC_EVENT_BASE;
+	if (offset >= SONY_EC_CAP_SLOT_COUNT) {
+		ERROR("notify event 0x%04" B_PRIx32 " is outside the capability "
+			"table\n", value);
+		return;
+	}
+
+	TRACE("notify event 0x%04" B_PRIx32 " -> slot %" B_PRIu32
+		" -> handle 0x%04x\n", value, offset, device->capabilities[offset]);
+
+	uint32 clearResult = 0;
+	sony_ec_call_int(device, "SN05", true, 1 << offset, &clearResult);
+}
+
+
+//	#pragma mark - device module API
+
+
+static status_t
+sony_ec_init_device(void *_cookie, void **cookie)
+{
+	// sSonyEcDevice is set up eagerly in sony_ec_register_child_devices(),
+	// since init_device() is only called once something actually opens
+	// power/sony_ec/0 -- and nothing does by default. We still want the
+	// capability table probed and the notify handler installed
+	// unconditionally at boot, not only if/when a client shows up.
+	if (sSonyEcDevice == NULL) {
+		ERROR("init_device called without a set up device\n");
+		return B_ERROR;
+	}
+
+	*cookie = sSonyEcDevice;
+	return B_OK;
+}
+
+
+static void
+sony_ec_uninit_device(void *_cookie)
+{
+	// The device is torn down in sony_ec_uninit_driver(), not here, since
+	// it was set up outside of the open()-triggered init_device() lifecycle
+	// too. Nothing to do per-close.
+}
+
+
+static status_t
+sony_ec_open(void *_cookie, const char *path, int flags, void **cookie)
+{
+	*cookie = _cookie;
+	return B_OK;
+}
+
+
+static status_t
+sony_ec_read(void *_cookie, off_t position, void *buffer, size_t *numBytes)
+{
+	sony_ec_device_info *device = (sony_ec_device_info *)_cookie;
+	if (*numBytes < sizeof(uint32)) {
+		*numBytes = 0;
+		return B_IO_ERROR;
+	}
+
+	if (user_memcpy(buffer, &device->brightness, sizeof(uint32)) < B_OK)
+		return B_BAD_ADDRESS;
+
+	*numBytes = sizeof(uint32);
+	return B_OK;
+}
+
+
+static status_t
+sony_ec_write(void *_cookie, off_t position, const void *buffer,
+	size_t *numBytes)
+{
+	sony_ec_device_info *device = (sony_ec_device_info *)_cookie;
+
+	// Accept a brightness level as an ASCII decimal string (e.g. "5"), so
+	// it's directly testable from a shell with something like
+	// `echo 5 > /dev/power/sony_ec/0`, without needing a dedicated tool.
+	char text[8];
+	size_t length = *numBytes;
+	if (length >= sizeof(text))
+		length = sizeof(text) - 1;
+	if (user_memcpy(text, buffer, length) < B_OK)
+		return B_BAD_ADDRESS;
+	text[length] = '\0';
+
+	uint32 level = (uint32)strtoul(text, NULL, 10);
+	if (level > 8)
+		level = 8;
+
+	uint32 result = 0;
+	status_t status = sony_ec_call_int(device, "SBRT", true, level, &result);
+	if (status == B_OK) {
+		device->brightness = level;
+		TRACE("brightness set to %" B_PRIu32 " (SBRT)\n", level);
+	} else {
+		ERROR("SBRT failed: %s\n", strerror(status));
+	}
+
+	// Read the level straight back from the EC (not just device->brightness,
+	// which we just set locally): if this still reports the OLD value, SBRT
+	// is a no-op on this model at the ACPI level. If it reports the NEW
+	// value, the EC accepted it, but whatever's between the EC and the
+	// actual panel backlight isn't responding -- a different, hardware-
+	// level problem this driver can't do anything more about.
+	uint32 readBack = 0xffffffff;
+	status_t readStatus = sony_ec_call_int(device, "GBRT", false, 0,
+		&readBack);
+	TRACE("brightness read-back after SBRT: status %s, value %" B_PRIu32
+		"\n", strerror(readStatus), readBack);
+
+	*numBytes = length;
+	return status;
+}
+
+
+static status_t
+sony_ec_control(void *_cookie, uint32 op, void *arg, size_t len)
+{
+	return B_DEV_INVALID_IOCTL;
+}
+
+
+static status_t
+sony_ec_close(void *cookie)
+{
+	return B_OK;
+}
+
+
+static status_t
+sony_ec_free(void *cookie)
+{
+	return B_OK;
+}
+
+
+//	#pragma mark - driver module API
+
+
+static float
+sony_ec_support(device_node *parent)
+{
+	const char *bus;
+	if (sDeviceManager->get_attr_string(parent, B_DEVICE_BUS, &bus, false)
+			!= B_OK || strcmp(bus, "acpi") != 0) {
+		return 0.0;
+	}
+
+	uint32 deviceType;
+	if (sDeviceManager->get_attr_uint32(parent, ACPI_DEVICE_TYPE_ITEM,
+			&deviceType, false) != B_OK || deviceType != ACPI_TYPE_DEVICE) {
+		return 0.0;
+	}
+
+	const char *hid;
+	if (sDeviceManager->get_attr_string(parent, ACPI_DEVICE_HID_ITEM, &hid,
+			false) != B_OK || strcmp(hid, SONY_EC_HID) != 0) {
+		return 0.0;
+	}
+
+	TRACE("found Sony SNC device (%s)\n", hid);
+	return 0.6;
+}
+
+
+static status_t
+sony_ec_register_device(device_node *node)
+{
+	device_attr attrs[] = {
+		{ B_DEVICE_PRETTY_NAME, B_STRING_TYPE,
+			{ .string = "Sony Notebook Control" }},
+		{ NULL }
+	};
+
+	return sDeviceManager->register_node(node, SONY_EC_MODULE_NAME, attrs,
+		NULL, NULL);
+}
+
+
+static status_t
+sony_ec_init_driver(device_node *node, void **_driverCookie)
+{
+	*_driverCookie = node;
+	return B_OK;
+}
+
+
+static void
+sony_ec_uninit_driver(void *driverCookie)
+{
+	if (sSonyEcDevice == NULL)
+		return;
+
+	sSonyEcDevice->acpi->remove_notify_handler(sSonyEcDevice->acpi_cookie,
+		ACPI_DEVICE_NOTIFY, sony_ec_notify_handler);
+	free(sSonyEcDevice);
+	sSonyEcDevice = NULL;
+}
+
+
+static status_t
+sony_ec_register_child_devices(void *_cookie)
+{
+	device_node *node = (device_node *)_cookie;
+
+	// Set up (and probe) the device here, unconditionally, rather than in
+	// init_device(): init_device() is only called once something actually
+	// opens power/sony_ec/0, and nothing does that on its own -- this is a
+	// bring-up/diagnostic driver that needs its capability table logged
+	// and its notify handler installed at boot regardless of whether any
+	// client ever opens the device node.
+	sony_ec_device_info *device = (sony_ec_device_info *)calloc(1,
+		sizeof(*device));
+	if (device == NULL)
+		return B_NO_MEMORY;
+
+	device->node = node;
+
+	device_node *parent = sDeviceManager->get_parent_node(node);
+	sDeviceManager->get_driver(parent, (driver_module_info **)&device->acpi,
+		(void **)&device->acpi_cookie);
+	sDeviceManager->put_node(parent);
+
+	if (device->acpi == NULL) {
+		ERROR("could not get acpi device driver from parent node\n");
+		free(device);
+		return B_ERROR;
+	}
+
+	if (device->acpi->install_notify_handler(device->acpi_cookie,
+			ACPI_DEVICE_NOTIFY, sony_ec_notify_handler, device) != B_OK) {
+		ERROR("can't install notify handler\n");
+	}
+
+	sony_ec_probe_capabilities(device);
+
+	sSonyEcDevice = device;
+
+	return sDeviceManager->publish_device(node, "power/sony_ec/0",
+		SONY_EC_DEVICE_MODULE_NAME);
+}
+
+
+module_dependency module_dependencies[] = {
+	{ B_DEVICE_MANAGER_MODULE_NAME, (module_info **)&sDeviceManager },
+	{ B_ACPI_MODULE_NAME, (module_info **)&sAcpi },
+	{}
+};
+
+
+driver_module_info sony_ec_driver_module = {
+	{
+		SONY_EC_MODULE_NAME,
+		0,
+		NULL
+	},
+
+	sony_ec_support,
+	sony_ec_register_device,
+	sony_ec_init_driver,
+	sony_ec_uninit_driver,
+	sony_ec_register_child_devices,
+	NULL,	// rescan
+	NULL,	// removed
+};
+
+
+struct device_module_info sony_ec_device_module = {
+	{
+		SONY_EC_DEVICE_MODULE_NAME,
+		0,
+		NULL
+	},
+
+	sony_ec_init_device,
+	sony_ec_uninit_device,
+	NULL,
+
+	sony_ec_open,
+	sony_ec_close,
+	sony_ec_free,
+	sony_ec_read,
+	sony_ec_write,
+	NULL,
+	sony_ec_control,
+	NULL,
+	NULL
+};
+
+module_info *modules[] = {
+	(module_info *)&sony_ec_driver_module,
+	(module_info *)&sony_ec_device_module,
+	NULL
+};

+		return 0;
+	}
+
+	if (argc > 1) {
+		int32 gsi = atoi(argv[1]);
+		struct ioapic* ioapic = find_ioapic(gsi);
+		if (ioapic == NULL) {
+			kprintf("gsi %" B_PRId32 " is not handled by any io-apic\n", gsi);
+			return 0;
+		}
+
+		print_ioapic(*ioapic);
+		dump_redirection_entry(*ioapic, gsi - ioapic->global_interrupt_base);
+		return 0;
+	}
+
+	for (struct ioapic* ioapic = sIOAPICs; ioapic != NULL;
+			ioapic = ioapic->next) {
+		print_ioapic(*ioapic);
+		for (int32 pin = 0; pin <= ioapic->max_redirection_entry; pin++)
+			dump_redirection_entry(*ioapic, pin);
+	}
+
+	return 0;

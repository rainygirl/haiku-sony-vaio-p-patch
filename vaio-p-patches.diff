+size_t
+UVCCamDevice::MaxRawFrameSize()
+{
+	// fMaxVideoFrameSize comes from the negotiated probe/commit response
+	// (_ProbeCommitFormat()) and was meant to be exact for uncompressed
+	// formats -- but diagnostic logging caught it stuck at 614400 (a
+	// 640x480 frame) while VideoFrame() and the actual stream were at
+	// 320x240 (real frame size 153600), a 4x mismatch. Whatever the exact
+	// cause (some path where StartTransfer()/_ProbeCommitFormat() ran
+	// against a different fUncompressedFrameIndex than the one
+	// AcceptVideoFrame() later settled VideoFrame() on), trusting that
+	// stale value made the deframer's frame-boundary backstop essentially
+	// never fire at the right point -- frames came out anywhere from ~1
+	// packet to ~3x the real expected size, never landing on it.
+	// Computing directly from VideoFrame() instead -- the same source
+	// FillFrameBuffer()/_DecodeYUY2() already use -- means the backstop
+	// can never disagree with what decode itself expects, regardless of
+	// what caused fMaxVideoFrameSize to drift.
+	long int width = (long)(VideoFrame().right - VideoFrame().left + 1);
+	long int height = (long)(VideoFrame().bottom - VideoFrame().top + 1);
+	if (width <= 0 || height <= 0)
+		return 0;
+	return fIsYUY2 ? (size_t)width * height * 2 : (size_t)width * height;
+}
